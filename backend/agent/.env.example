# Windows VPS Agent Environment
# Copy to .env and fill in your values

# Remote Ubuntu server PostgreSQL
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@91.98.20.163:5432/copytrade

# Remote Ubuntu server Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@91.98.20.163:6379/0

# Encryption key for MT5 credentials (must match the API server key)
MT5_CREDENTIAL_KEY=your-32-byte-base64-key====

# MT5 Terminal path (Windows)
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Polling interval (ms) — lower = faster detection, higher CPU
MASTER_POLL_INTERVAL_MS=50

# Max slippage in points before rejecting a copy
MAX_SLIPPAGE_POINTS=30

# How often to sync with PostgreSQL for new accounts (seconds)
DB_SYNC_INTERVAL_S=30
